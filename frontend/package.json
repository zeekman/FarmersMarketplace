{
  "name": "farmers-marketplace-frontend",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build && echo Bundle report: dist/bundle-report.html",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write . --ignore-path ../.prettierignore"
  },
  "devDependencies_note": "run: npm install --save-dev rollup-plugin-visualizer @axe-core/react --legacy-peer-deps",
  "dependencies": {
    "dompurify": "^3.3.3",
    "i18next": "^26.0.1",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^17.0.1",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@eslint/js": "^8.57.1",
    "@playwright/test": "^1.44.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^6.2.0",
    "vitest": "^3.1.0",
    "wait-on": "^7.2.0"
  }
}
