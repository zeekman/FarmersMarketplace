PORT=4000

# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# Stellar network: 'testnet' or 'mainnet' (defaults to testnet if omitted)
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
CLIENT_ORIGIN=http://localhost:3000
NODE_ENV=development

# Stellar Network Configuration
# Options: "testnet" (default) | "mainnet"
STELLAR_NETWORK=testnet
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development
# Required when STELLAR_NETWORK=mainnet — prevents accidental real-fund transactions
# STELLAR_MAINNET_CONFIRMED=true
# Optional: override the Horizon server URL (defaults to the standard testnet/mainnet URL)
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Email notifications (optional — leave SMTP_HOST blank to disable)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@farmersmarketplace.com
