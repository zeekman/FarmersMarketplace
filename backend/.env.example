PORT=4000

# Database — set DATABASE_URL to use PostgreSQL (production)
# Leave unset to use SQLite (local development, default)
# DATABASE_URL=postgresql://user:password@localhost:5432/farmersmarketplace

# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

CLIENT_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
# Domain used in federation addresses (e.g. farmer*farmersmarket.io)
FEDERATION_DOMAIN=farmersmarket.io
# CORS configuration — comma-separated list of allowed origins
# Defaults to FRONTEND_ORIGIN if not set
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
NODE_ENV=development

# Stellar Network Configuration
# Options: "testnet" (default) | "mainnet"
STELLAR_NETWORK=testnet
# Required when STELLAR_NETWORK=mainnet — prevents accidental real-fund transactions
# STELLAR_MAINNET_CONFIRMED=true
# Optional: override the Horizon server URL
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Email notifications (optional — leave SMTP_HOST blank to disable)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@farmersmarketplace.com

# Rate limiting (optional — defaults shown)
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERAL_MAX=100

# Admin seed script (used by: node backend/scripts/seed-admin.js)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@farmersmarketplace.com
ADMIN_PASSWORD=ChangeMe1!
